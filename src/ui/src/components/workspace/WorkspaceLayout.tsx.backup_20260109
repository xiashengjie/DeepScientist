function LeftPanel({
  width,
  projectId,
  onClose,
  readOnly,
  onEnterHome,
  onExitHome,
}: {
  width: number
  projectId: string
  onClose: () => void
  readOnly?: boolean
  onEnterHome?: () => void
  onExitHome?: () => void
}) {
  const readOnlyMode = Boolean(readOnly)
  const { addToast } = useToast()
  const openTab = useTabsStore((state) => state.openTab)
  const { createFolder, upload, refresh, isLoading } = useFileTreeStore()
  const { openFileInTab, downloadFile, openNotebook } = useOpenFile()
  const fileInputRef = React.useRef<HTMLInputElement>(null)
  const explorerBodyRef = React.useRef<HTMLDivElement | null>(null)
  const cliExplorerRef = React.useRef<CliExplorerTreeHandle | null>(null)
  const [activeExplorer, setActiveExplorer] = React.useState<'files' | 'cli' | 'arxiv'>('files')
  const [createFileOpen, setCreateFileOpen] = React.useState(false)
  const [hasCliServers, setHasCliServers] = React.useState(false)

  React.useEffect(() => {
    let active = true
    const loadServers = async () => {
      try {
        const servers = await listCliServers(projectId)
        if (!active) return
        setHasCliServers(servers.length > 0)
      } catch {
        if (active) setHasCliServers(false)
      }
    }
    void loadServers()
    const interval = window.setInterval(loadServers, 15000)
    return () => {
      active = false
      window.clearInterval(interval)
    }
  }, [projectId])

  React.useEffect(() => {
    if (!hasCliServers && activeExplorer === 'cli') {
      setActiveExplorer('files')
    }
  }, [activeExplorer, hasCliServers])

  const openPluginTab = React.useCallback(
    (pluginId: string, title: string, customData?: Record<string, unknown>) => {
      if (readOnlyMode) return
      onExitHome?.()
      openTab({
        pluginId,
        context: { type: 'custom', customData: { projectId, ...customData } },
        title,
      })
    },
    [onExitHome, openTab, projectId, readOnlyMode]
  )

  const handleFileOpen = React.useCallback(
    async (file: FileNode) => {
      onExitHome?.()
      if (file.type === 'folder' && file.folderKind === 'latex') {
        openTab({
          pluginId: '@ds/plugin-latex',
          context: {
            type: 'custom',
            resourceId: file.id,
            resourceName: file.name,
            customData: {
              projectId,
              latexFolderId: file.id,
              mainFileId: file.latex?.mainFileId ?? null,
              readOnly: readOnlyMode,
            },
          },
          title: file.name,
        })
        return
      }
      if (file.type === 'notebook') {
        openNotebook(file.id, file.name, projectId, { readonly: readOnlyMode })
        return
      }
      await openFileInTab(file, {
        customData: {
          projectId,
          fileMeta: {
            updatedAt: file.updatedAt,
            sizeBytes: file.size,
            mimeType: file.mimeType,
          },
        },
      })
    },
    [onExitHome, openFileInTab, openNotebook, projectId, readOnlyMode]
  )

  const handleFileDownload = React.useCallback(
    async (file: FileNode) => {
      try {
        await downloadFile(file)
        addToast({
          type: 'success',
          title: 'Download started',
          description: file.name,
          duration: 1800,
        })
      } catch (error) {
        console.error('Download failed:', error)
        addToast({
          type: 'error',
          title: 'Download failed',
          description: 'Please try again.',
        })
      }
    },
    [addToast, downloadFile]
  )

  const handleNewFolder = React.useCallback(async () => {
    if (readOnlyMode) return
    try {
      await createFolder(null, 'New Folder')
      addToast({ type: 'success', title: 'Folder created', duration: 1800 })
    } catch (error) {
      console.error('Failed to create folder:', error)
      addToast({ type: 'error', title: 'Create folder failed', description: 'Please try again.' })
    }
  }, [addToast, createFolder, readOnlyMode])

  const handleUploadClick = React.useCallback(() => {
    if (readOnlyMode) return
    fileInputRef.current?.click()
  }, [readOnlyMode])

  const handleFileSelect = React.useCallback(
    async (e: React.ChangeEvent<HTMLInputElement>) => {
      if (readOnlyMode) return
      const files = Array.from(e.target.files || [])
      if (files.length > 0) {
        try {
          await upload(null, files)
          addToast({
            type: 'success',
            title: 'Upload started',
            description: `${files.length} file(s)`,
            duration: 2200,
          })
        } catch (error) {
          console.error('Upload failed:', error)
          addToast({ type: 'error', title: 'Upload failed', description: 'Please try again.' })
        }
      }
      e.target.value = ''
    },
    [addToast, upload, readOnlyMode]
  )

  const handleRefresh = React.useCallback(async () => {
    try {
      await refresh()
      addToast({ type: 'success', title: 'Refreshed', duration: 1200 })
    } catch (error) {
      console.error('Failed to refresh:', error)
      addToast({ type: 'error', title: 'Refresh failed', description: 'Please try again.' })
    }
  }, [addToast, refresh])

  const isFilesView = activeExplorer === 'files'
  const isCliView = activeExplorer === 'cli'
  const isArxivView = activeExplorer === 'arxiv'
  const disableExplorerActions = readOnlyMode || isArxivView

  const handleExplorerNewFile = React.useCallback(() => {
    if (disableExplorerActions) return
    if (isFilesView) {
      setCreateFileOpen(true)
      return
    }
    cliExplorerRef.current?.createFile()
  }, [disableExplorerActions, isFilesView])

  const handleExplorerNewFolder = React.useCallback(() => {
    if (disableExplorerActions) return
    if (isFilesView) {
      void handleNewFolder()
      return
    }
    cliExplorerRef.current?.createFolder()
  }, [disableExplorerActions, handleNewFolder, isFilesView])

  const handleExplorerUpload = React.useCallback(() => {
    if (disableExplorerActions) return
    if (isFilesView) {
      handleUploadClick()
      return
    }
    cliExplorerRef.current?.upload()
  }, [disableExplorerActions, handleUploadClick, isFilesView])

  const handleExplorerRefresh = React.useCallback(() => {
    if (disableExplorerActions) return
    if (isFilesView) {
      void handleRefresh()
      return
    }
    cliExplorerRef.current?.refresh()
  }, [disableExplorerActions, handleRefresh, isFilesView])

  return (
    <div className="panel left-panel" style={{ width, minWidth: width }}>
      {/* Header */}
      <div className="panel-header flex flex-nowrap items-center">
        <div className="flex items-center gap-2">
          <div className="traffic-lights">
            <button
              type="button"
              className="traffic-light-close-button"
              onClick={onClose}
              title="Close Explorer"
              aria-label="Close Explorer"
            >
              <X className="h-3 w-3" />
            </button>
          </div>
          <span style={{ opacity: 0.8 }}>Explorer</span>
        </div>
        <div className="ml-auto flex items-center">
          <div
            className={cn(
              'flex items-center gap-0.5 whitespace-nowrap rounded-full border p-0.5 shadow-sm',
              'border-white/[0.16] bg-[var(--bg-panel-left)]'
            )}
            role="tablist"
            aria-label="Explorer views"
          >
            <button
              type="button"
              className={cn(
                'inline-flex h-7 w-7 items-center justify-center rounded-full transition-colors',
                'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9b8352]/40',
                isFilesView
                  ? 'bg-[#9b8352] text-white shadow-sm'
                  : 'text-[var(--text-muted-on-dark)] hover:bg-[#9b8352]/[0.18] hover:text-[var(--text-on-dark)]'
              )}
              onClick={() => setActiveExplorer('files')}
              role="tab"
              aria-selected={isFilesView}
              aria-label="Files"
              title="Files"
            >
              <FileText className="h-4 w-4" />
            </button>
            {hasCliServers ? (
              <button
                type="button"
                className={cn(
                  'inline-flex h-7 w-7 items-center justify-center rounded-full transition-colors',
                  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9b8352]/40',
                  isCliView
                    ? 'bg-[#9b8352] text-white shadow-sm'
                    : 'text-[var(--text-muted-on-dark)] hover:bg-[#9b8352]/[0.18] hover:text-[var(--text-on-dark)]'
                )}
                onClick={() => setActiveExplorer('cli')}
                role="tab"
                aria-selected={isCliView}
                aria-label="CLI Files"
                title="CLI Files"
              >
                <Terminal className="h-4 w-4" />
              </button>
            ) : null}
            <button
              type="button"
              className={cn(
                'inline-flex h-7 w-7 items-center justify-center rounded-full transition-colors',
                'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9b8352]/40',
                isArxivView
                  ? 'bg-[#9b8352] text-white shadow-sm'
                  : 'text-[var(--text-muted-on-dark)] hover:bg-[#9b8352]/[0.18] hover:text-[var(--text-on-dark)]'
              )}
              onClick={() => setActiveExplorer('arxiv')}
              role="tab"
              aria-selected={isArxivView}
              aria-label="Arxiv"
              title="Arxiv"
            >
              <BookOpen className="h-4 w-4" />
            </button>
          </div>
        </div>
      </div>

      {/* File Tree Section */}
      <div className="flex-1 min-h-0 flex flex-col">
        <div className="flex items-center gap-3 px-4 py-2 border-b border-[var(--border-dark)]">
          <div className="ml-auto flex items-center gap-0.5">
            <Button
              type="button"
              variant="ghost"
              size="icon"
              onClick={handleExplorerNewFile}
              disabled={disableExplorerActions}
              className="h-7 w-7 rounded-lg p-0 text-[var(--text-muted-on-dark)] hover:bg-white/[0.08] hover:text-[var(--text-on-dark)]"
              title={
                disableExplorerActions
                  ? readOnlyMode
                    ? 'View only'
                    : 'Unavailable in Arxiv view'
                  : 'New File'
              }
              aria-label="New File"
            >
              <FilePlus className="h-3.5 w-3.5" />
            </Button>
            <Button
              type="button"
              variant="ghost"
              size="icon"
              onClick={handleExplorerNewFolder}
              disabled={disableExplorerActions}
              className="h-7 w-7 rounded-lg p-0 text-[var(--text-muted-on-dark)] hover:bg-white/[0.08] hover:text-[var(--text-on-dark)]"
              title={
                disableExplorerActions
                  ? readOnlyMode
