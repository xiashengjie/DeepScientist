      } as MessageContent,
    })

    if (preparedAttachments.length > 0) {
      appendMessage({
        id: createMessageId('attachments'),
        type: 'attachments',
        content: {
          role: 'user',
          attachments: preparedAttachments,
          timestamp: Math.floor(Date.now() / 1000),
        } as AttachmentsContent,
      })
    }

    setInputMessage('')
    setAttachments([])
    setRecentFilesEnabled(false)

    const contextSnapshot = buildContext()
    await sendMessage({
      sessionId: resolvedSessionId,
      message: text,
      attachments: preparedAttachments,
      recentFiles: recentFilesEnabled ? recentFiles : undefined,
      surface: mode,
      executionTarget,
      cliServerId,
      metadata: contextSnapshot ? { context: contextSnapshot } : undefined,
    })
  }, [
    appendMessage,
    attachments,
    buildContext,
    cliServerId,
    ensureSession,
    executionTarget,
    inputMessage,
    mode,
    prefersReducedMotion,
    readOnlyMode,
    recentFiles,
    recentFilesEnabled,
    setWelcomeIntroState,
    sendMessage,
    introEnabled,
    welcomeIntroState,
  ])

  const handleStop = async () => {
    if (!sessionId) return
    stop()
    await stopSession(sessionId)
  }

  const handleSessionSelect = useCallback(
    (nextId: string) => {
      if (!projectId) return
      if (draftSessionId && nextId === draftSessionId) return
      setDraftSessionId(null)
      setSessionId(projectId, nextId)
    },
    [draftSessionId, projectId, setDraftSessionId, setSessionId]
  )

  const handleSessionDelete = useCallback(
    async (targetId: string) => {
      if (!projectId || readOnlyMode) return
      if (draftSessionId && targetId === draftSessionId) {
        setDraftSessionId(null)
        resetConversation()
        return
      }
      const confirmDelete = window.confirm('Delete this session? This cannot be undone.')
      if (!confirmDelete) return
      try {
        await deleteSession(targetId)
        setSessions((current) => current.filter((item) => item.session_id !== targetId))
        if (sessionId === targetId) {
          clearSessionId(projectId)
          setLastEventId(targetId, null)
          resetConversation()
        }
      } catch (error) {
        addToast({
          type: 'error',
          title: 'Unable to delete session',
          description: 'Please try again in a moment.',
        })
      }
    },
    [
      addToast,
      clearSessionId,
      draftSessionId,
      projectId,
      readOnlyMode,
      resetConversation,
      sessionId,
      setLastEventId,
      setDraftSessionId,
      setSessions,
    ]
  )

  useEffect(() => {
    if (!fileListOpen || !sessionId) return
    let active = true
    setSessionFilesLoading(true)
    getSessionFiles(sessionId)
      .then((files) => {
        if (!active) return
        setSessionFiles(files)
      })
      .catch(() => {
        if (!active) return
        addToast({
          type: 'error',
          title: 'Unable to load session files',
          description: 'Please try again later.',
        })
      })
      .finally(() => {
        if (active) {
          setSessionFilesLoading(false)
        }
      })
    return () => {
      active = false
    }
  }, [addToast, fileListOpen, sessionId])

  const syncMeta = useCallback(() => {
    const meta: AiManusChatMeta = {
      threadId: sessionId ?? null,
      historyOpen,
      isResponding: isStreamActive,
      ready: Boolean(sessionId),
      error: connection.error ?? null,
      title,
      toolPanelVisible,
    }
    onMetaChange?.(meta)
  }, [connection.error, historyOpen, isStreamActive, onMetaChange, sessionId, title, toolPanelVisible])

  useEffect(() => {
    syncMeta()
  }, [syncMeta])

  useEffect(() => {
    const actions: AiManusChatActions = {
      toggleHistory: () => {
        if (!showHistoryPanel) return
        setHistoryOpen((value) => !value)
      },
      startNewThread: startNewSession,
      setThreadId: (threadId) => {
        if (!projectId) return
        setDraftSessionId(null)
        if (!threadId) {
          clearSessionId(projectId)
          resetConversation()
          return
        }
        setSessionId(projectId, threadId)
      },
      focusComposer: () => {
        composerRef.current?.focus()
      },
      setComposerValue: (text, focus = false) => {
        setInputMessage(text)
        if (focus) {
          window.setTimeout(() => composerRef.current?.focus(), 0)
        }
      },
      submitComposer: () => {
        handleSubmit()
      },
      openToolPanel: () => {
        if (mode !== 'welcome' || !toolPanelEnabled) return
        if (activeTool) {
          setToolPanelView('tool')
          setToolPanelOpen(true)
          return
        }
        const lastTool = lastNoMessageToolRef.current
        if (lastTool) {
          setActiveTool(lastTool)
          setToolPanelLive(lastTool.status === 'calling')
          setToolPanelView('tool')
          setToolPanelOpen(true)
          return
        }
        const openTerminal = async () => {
          const resolvedSessionId = await ensureSession()
          if (!resolvedSessionId) return
          setToolPanelView('terminal')
          setToolPanelOpen(true)
        }
        void openTerminal()
      },
    }
    onActionsChange?.(actions)
    return () => {
      onActionsChange?.(null)
    }
  }, [
    activeTool,
    clearSessionId,
    handleSubmit,
    ensureSession,
    mode,
    onActionsChange,
    projectId,
    resetConversation,
    setDraftSessionId,
    setSessionId,
    setToolPanelOpen,
    setToolPanelView,
    showHistoryPanel,
    startNewSession,
    toolPanelEnabled,
  ])

  useEffect(() => {
    if (!prefill) return
    setInputMessage(prefill.text)
    if (prefill.focus) {
      window.setTimeout(() => composerRef.current?.focus(), 0)
    }
  }, [prefill])

  useEffect(() => {
    if (toolPanelEnabled) return
    setToolPanelLive(false)
  }, [toolPanelEnabled])

  const isLastNoMessageTool = useCallback((tool: ToolContent) => {
    return tool.tool_call_id === lastNoMessageToolRef.current?.tool_call_id
  }, [])

  const canAutoOpenToolPanel = useCallback((tool: ToolContent) => {
    const category = resolveToolCategory(tool)
    return category === 'shell' || category === 'search' || category === 'file'
  }, [])

  const isLiveTool = useCallback(
    (tool: ToolContent) => {
      if (tool.status === 'calling') return true
      if (!isLastNoMessageTool(tool)) return false
      const timestampMs = normalizeTimestampMs(tool.timestamp)
      if (!timestampMs) return false
      return timestampMs > Date.now() - 5 * 60 * 1000
    },
    [isLastNoMessageTool]
  )

  const handleToolPanelOpen = useCallback(
    (tool: ToolContent, live: boolean, forceOpen = false) => {
      setActiveTool(tool)
      setToolPanelLive(live)
      setToolPanelView('tool')
      if (!toolPanelEnabled) return
      if (forceOpen) {
        setToolPanelOpen(true)
      }
    },
    [toolPanelEnabled, setToolPanelView]
  )

  useEffect(() => {
    if (mode !== 'welcome' || !openToolPanel) return
    if (!toolPanelAutoOpenRef.current) return
    if (restoringRef.current) return
    const lastTool = lastNoMessageToolRef.current
    if (lastTool) {
      if (canAutoOpenToolPanel(lastTool)) {
        handleToolPanelOpen(lastTool, isLiveTool(lastTool), true)
      }
      toolPanelAutoOpenRef.current = false
      return
    }
    const openTerminal = async () => {
      const resolvedSessionId = sessionId ?? (await ensureSession())
      if (!resolvedSessionId) return
      setToolPanelView('terminal')
      setToolPanelOpen(true)
    }
    void openTerminal()
    toolPanelAutoOpenRef.current = false
  }, [canAutoOpenToolPanel, ensureSession, handleToolPanelOpen, isLiveTool, mode, openToolPanel, sessionId])

  const collapseActiveReasoning = useCallback(() => {
    const active = lastReasoningRef.current
    if (!active || active.collapsed) return
    active.collapsed = true
    updateMessages([...messagesRef.current])
  }, [updateMessages])

  const handleQuestionSubmit = useCallback(
    async (payload: {
      answers: Record<string, string | number | boolean | Array<string | number>>
      text: string
    }) => {
      if (!sessionId || !questionPrompt) {
        throw new Error('question_prompt_unavailable')
      }
      try {
        await submitToolOutput(sessionId, questionPrompt.toolCallId, payload)
        setQuestionPrompt(null)
        setCopilotStatus(null)
      } catch (error) {
        addToast({
          type: 'error',
          title: 'Failed to submit answers',
          description: 'Please try again.',
        })
        throw error
      }
    },
    [addToast, questionPrompt, sessionId]
  )

  const startDisplayLock = useCallback(
    (id: string, kind: DisplayLockKind) => {
      if (restoringRef.current) return
      const current = displayLockRef.current
      if (current) return
      displayLockRef.current = { id, kind }
      setDisplayLockState({ id, kind })
      if (displayLockTimerRef.current) {
        window.clearTimeout(displayLockTimerRef.current)
      }
      displayLockTimerRef.current = window.setTimeout(() => {
        if (!displayLockRef.current) return
        if (displayLockRef.current.id !== id || displayLockRef.current.kind !== kind) return
        displayLockRef.current = null
        setDisplayLockState(null)
        displayLockTimerRef.current = null
        flushBufferedEvents()
      }, DISPLAY_LOCK_TIMEOUT_MS)
    },
    [flushBufferedEvents]
  )

  const endDisplayLock = useCallback(
    (id: string, kind: DisplayLockKind) => {
      const current = displayLockRef.current
      if (!current || current.id !== id || current.kind !== kind) return
      displayLockRef.current = null
      setDisplayLockState(null)
      if (displayLockTimerRef.current) {
        window.clearTimeout(displayLockTimerRef.current)
        displayLockTimerRef.current = null
      }
      flushBufferedEvents()
    },
    [flushBufferedEvents]
  )

  const handleEvent = useCallback(
    (event: AgentSSEEvent) => {
      if (!event?.data || typeof event.data !== 'object') return
      if (!cacheReplayRef.current && sessionId) {
        appendCachedEvent(sessionId, event)
      }
      const metadata = event.data?.metadata
      if (
        !restoringRef.current &&
        isCopilotSurface &&
        (metadata?.surface || metadata?.reply_to_surface) &&
        (event.event === 'message' || event.event === 'attachments')
      ) {
        const role = (event.data as MessageEventData).role
        const targetSurface =
          role === 'assistant'
            ? metadata.reply_to_surface ?? metadata.surface
            : metadata.surface ?? metadata.reply_to_surface
        if (targetSurface && targetSurface !== mode) return
      }

      const eventId = event.data?.event_id
      const isTransientDeltaEvent =
        (event.event === 'message' || event.event === 'reasoning') &&
        typeof (event.data as Partial<MessageEventData>)?.delta === 'string' &&
        Boolean((event.data as Partial<MessageEventData>).delta)
      if (eventId && sessionId && !isTransientDeltaEvent) {
        setLastEventId(sessionId, eventId)
      }

      if (shouldBufferEvent(event)) {
        bufferedEventsRef.current.push(event)
        return
      }

      if (event.event === 'message') {
        const messageData = event.data as Partial<MessageEventData> & {
          message?: unknown
          text?: unknown
        }
        const role = coerceRole(messageData.role)
        const delta = typeof messageData.delta === 'string' ? messageData.delta : ''
        const timestamp = coerceTimestamp(messageData.timestamp)
        const messageId =
          typeof messageData.event_id === 'string' ? messageData.event_id : createMessageId(role)

        if (role === 'assistant' && delta) {
          const existingIndex = messagesRef.current.findIndex((item) => item.id === messageId)
          if (existingIndex >= 0) {
            const next = [...messagesRef.current]
            const existing = next[existingIndex]
            if (existing.type === 'assistant') {
              const existingContent = existing.content as MessageContent
              existingContent.content += delta
              existingContent.status = 'in_progress'
              existingContent.timestamp = timestamp
              if (messageData.metadata) {
                existingContent.metadata = messageData.metadata
              }
              next[existingIndex] = { ...existing, content: existingContent }
              updateMessages(next)
            }
          } else {
            appendMessage({
              id: messageId,
              type: 'assistant',
              content: {
                ...messageData,
                role,
                content: delta,
                timestamp,
                status: 'in_progress',
              } as MessageContent,
            })
          }
          if (isCopilotSurface) setCopilotStatus(null)
          return
        }

        const contentValue =
          typeof messageData.content === 'string'
            ? messageData.content
            : typeof messageData.message === 'string'
              ? messageData.message
              : typeof messageData.text === 'string'
                ? messageData.text
                : messageData.content != null
                  ? String(messageData.content)
                  : ''
        const normalizedAttachments = normalizeAttachments(
          Array.isArray(messageData.attachments) ? messageData.attachments : undefined,
          sessionId
        )
        const pending = pendingUserRef.current
        if (role === 'user' && pending) {
          const pendingMatches =
            contentValue.trim() === pending.content.trim() &&
            normalizedAttachments.length === pending.attachments.length &&
            normalizedAttachments.every((file) =>
              pending.attachments.some((pendingFile) => pendingFile.filename === file.filename)
            )
          if (pendingMatches) {
            pendingUserRef.current = null
            return
          }
        }
        if (role === 'assistant') {
          collapseActiveReasoning()
        }
        let updatedExisting = false
        if (role === 'assistant') {
          const existingIndex = messagesRef.current.findIndex((item) => item.id === messageId)
          if (existingIndex >= 0) {
            const next = [...messagesRef.current]
            const existing = next[existingIndex]
            if (existing.type === 'assistant') {
              const existingContent = existing.content as MessageContent
              existingContent.content = contentValue
              existingContent.status = 'completed'
              existingContent.timestamp = timestamp
              if (messageData.metadata) {
                existingContent.metadata = messageData.metadata
              }
              next[existingIndex] = { ...existing, content: existingContent }
              updateMessages(next)
              updatedExisting = true
            }
          }
        }

        if (!updatedExisting) {
          appendMessage({
            id: messageId,
            type: role,
            content: {
              ...messageData,
              role,
              content: contentValue,
              timestamp,
              ...(role === 'assistant' ? { status: 'completed' } : {}),
            } as MessageContent,
          })
          if (role === 'assistant') {
            startDisplayLock(messageId, 'assistant')
          }
        }
        if (sessionId) {
          upsertSession(sessionId, {
            latest_message: contentValue,
            latest_message_at: timestamp,
            updated_at: timestamp,
            status: restoredStatusRef.current ?? null,
          })
        }

        if (normalizedAttachments.length > 0) {
          const key = buildAttachmentKey(role, timestamp, normalizedAttachments)
          if (!attachmentsSeenRef.current.has(key)) {
            attachmentsSeenRef.current.add(key)
            appendMessage({
              id: createMessageId('attachments'),
              type: 'attachments',
              content: {
                role,
                attachments: normalizedAttachments,
                timestamp,
              } as AttachmentsContent,
            })
          }
        }
        if (isCopilotSurface) setCopilotStatus(null)
        return
      }

      if (event.event === 'attachments') {
        const attachmentsData = event.data as Partial<AttachmentsEventData>
        const role = coerceRole(attachmentsData.role)
        const timestamp = coerceTimestamp(attachmentsData.timestamp)
        const normalized = normalizeAttachments(
          Array.isArray(attachmentsData.attachments) ? attachmentsData.attachments : undefined,
          sessionId
        )
        if (normalized.length === 0) return
        const key = buildAttachmentKey(role, timestamp, normalized)
        if (attachmentsSeenRef.current.has(key)) return
        attachmentsSeenRef.current.add(key)
        appendMessage({
          id: createMessageId('attachments'),
          type: 'attachments',
          content: {
            role,
            attachments: normalized,
            timestamp,
          } as AttachmentsContent,
        })
        return
      }

      if (event.event === 'reasoning') {
        const reasoningData = event.data as Partial<ReasoningEventData>
        const reasoningId =
          typeof reasoningData.reasoning_id === 'string' && reasoningData.reasoning_id
            ? reasoningData.reasoning_id
            : ''
        if (!reasoningId) return
        const status = reasoningData.status === 'completed' ? 'completed' : 'in_progress'
        const delta = typeof reasoningData.delta === 'string' ? reasoningData.delta : ''
        const contentValue =
          typeof reasoningData.content === 'string' ? reasoningData.content : ''
        const kind = coerceReasoningKind(reasoningData.kind)
        const timestamp = coerceTimestamp(reasoningData.timestamp)
        const reasoningKey = buildReasoningKey(reasoningId, kind)
        const existing = reasoningByIdRef.current.get(reasoningKey)
        if (kind === 'full') {
          const summaryKey = buildReasoningKey(reasoningId, 'summary')
          const summaryMessage = reasoningByIdRef.current.get(summaryKey)
          if (summaryMessage && summaryMessage.type === 'reasoning') {
            const summaryContent = summaryMessage.content as ReasoningContent
            if (summaryContent.status !== 'completed') {
              summaryContent.status = 'completed'
              updateMessages([...messagesRef.current])
            }
          }
        }
        if (existing && existing.type === 'reasoning') {
          const reasoningContent = existing.content as ReasoningContent
          if (contentValue) {
            reasoningContent.content = contentValue
          } else if (delta) {
            reasoningContent.content += delta
          }
          reasoningContent.status = status
          reasoningContent.kind = kind
          reasoningContent.timestamp = timestamp
          updateMessages([...messagesRef.current])
          lastReasoningRef.current = reasoningContent
          startDisplayLock(existing.id, 'reasoning')
          if (!restoringRef.current) {
            if (status === 'completed') {
              reasoningLocksRef.current.delete(reasoningId)
              if (reasoningLocksRef.current.size === 0) {
                flushBufferedEvents()
              }
            } else {
              reasoningLocksRef.current.add(reasoningId)
            }
          }
          return
        }
        if (!contentValue && !delta) return

        const message: ChatMessageItem = {
          id: typeof reasoningData.event_id === 'string' ? reasoningData.event_id : createMessageId('reasoning'),
          type: 'reasoning',
          content: {
            reasoning_id: reasoningId,
            status,
            content: contentValue || delta,
            kind,
            timestamp,
            collapsed: false,
          } as ReasoningContent,
        }
        appendMessage(message)
        reasoningByIdRef.current.set(reasoningKey, message)
        lastReasoningRef.current = message.content as ReasoningContent
        startDisplayLock(message.id, 'reasoning')
        if (!restoringRef.current) {
          if (status === 'completed') {
            reasoningLocksRef.current.delete(reasoningId)
            if (reasoningLocksRef.current.size === 0) {
              flushBufferedEvents()
            }
          } else {
            reasoningLocksRef.current.add(reasoningId)
          }
        }
        return
      }

      if (event.event === 'tool') {
        const toolData = event.data as Partial<ToolEventData>
        const functionName = typeof toolData.function === 'string' ? toolData.function : ''
        const toolCallId =
          typeof toolData.tool_call_id === 'string' && toolData.tool_call_id
            ? toolData.tool_call_id
            : createMessageId('tool')
        const status =
          toolData.status === 'calling' || toolData.status === 'called' ? toolData.status : 'called'
        const toolName = typeof toolData.name === 'string' ? toolData.name : ''

        if (!restoringRef.current && status === 'calling' && toolName !== 'message') {
          const seen = toolCallSeenRef.current
          if (!seen.has(toolCallId)) {
            seen.add(toolCallId)
            setToolCallCount((count) => count + 1)
          }
        }

        if (status === 'calling') {
          collapseActiveReasoning()
          if (!restoringRef.current && typeof window !== 'undefined') {
            window.dispatchEvent(
              new CustomEvent('ds:tool:call', {
                detail: {
                  toolCallId,
                  function: functionName,
                  name: toolName,
                  status,
                },
              })
            )
          }
        }

        if (!restoringRef.current && status === 'calling') {
          const preview = buildPdfToolPreview(toolData)
          if (preview) {
            previewPdfToolEffect(preview)
          }
        }

        if (functionName === 'context_read' && status === 'calling' && sessionId) {
          if (!restoringRef.current) {
            const context = buildContext()
            if (context) {
              void submitToolOutput(sessionId, toolCallId, { context })
            }
          }
          return
        }

        if (functionName === 'question_prompt') {
          if (restoringRef.current && restoredStatusRef.current !== 'waiting') {
            return
          }
          if (readOnlyMode) {
            setQuestionPrompt(null)
            return
          }
          if (status === 'calling') {
            setQuestionPrompt({
              toolCallId: toolCallId,
              args: (toolData.args ?? {}) as Record<string, unknown>,
            })
            if (isCopilotSurface) {
              setCopilotStatus('Waiting for your input')
            }
          } else if (status === 'called') {
            setQuestionPrompt(null)
            if (isCopilotSurface) {
              setCopilotStatus(null)
            }
          }
          return
        }

        if (functionName === 'mcp_status_update') {
          const seen = statusToolSeenRef.current
          const baseArgs =
            toolData.args && typeof toolData.args === 'object' && !Array.isArray(toolData.args)
              ? (toolData.args as Record<string, unknown>)
              : {}
          const statusMessage =
            typeof baseArgs.message === 'string'
              ? baseArgs.message
              : typeof baseArgs.text === 'string'
                ? baseArgs.text
                : ''
          const timestamp = coerceTimestamp(toolData.timestamp)
          const eventId =
            typeof toolData.event_id === 'string' && toolData.event_id ? toolData.event_id : ''
          const messageId = toolCallId
            ? `mcp-status-${toolCallId}`
            : eventId
              ? `mcp-status-${eventId}`
              : `mcp-status-${createMessageId('status')}`
          const toolContent: ToolContent = {
            ...(toolData as ToolEventData),
            tool_call_id: toolCallId,
            function: functionName,
            name: typeof toolData.name === 'string' && toolData.name ? toolData.name : 'message',
            status,
            args: {
              ...baseArgs,
              ...(statusMessage ? { message: statusMessage } : {}),
            },
            timestamp,
          }
          const existingIndex = messagesRef.current.findIndex((item) => item.id === messageId)
          if (existingIndex >= 0) {
            const next = [...messagesRef.current]
            const existing = next[existingIndex]
            if (existing.type === 'tool') {
              next[existingIndex] = { ...existing, content: toolContent }
              updateMessages(next)
            }
          } else if (statusMessage) {
            appendMessage({
              id: messageId,
              type: 'tool',
              content: toolContent,
            })
          }
          if (isCopilotSurface) {
            setCopilotStatus(null)
          }
          seen.add(toolCallId)
          return
        }

        const effects = [
          ...(toolData.ui_effect ? [toolData.ui_effect] : []),
          ...(toolData.ui_effects ?? []),
        ]
        const resolvedEffects =
          effects.length > 0 ? effects : buildFallbackEffects(toolData, status)
        if (resolvedEffects.length > 0 && !restoringRef.current) {
          resolvedEffects.forEach((effect) => handleUIEffect(effect, { surface: mode }))
        }

        if (isCopilotSurface) {
          const summary = `${toolData.name ?? 'tool'} · ${functionName}`
          setCopilotStatus(status === 'calling' ? summary : null)
        }

        const toolContent: ToolContent = {
          ...(toolData as ToolEventData),
          tool_call_id: toolCallId,
          function: functionName,
          name: typeof toolData.name === 'string' && toolData.name ? toolData.name : 'tool',
          status,
          args:
            toolData.args && typeof toolData.args === 'object' && !Array.isArray(toolData.args)
              ? (toolData.args as Record<string, unknown>)
              : {},
          timestamp: coerceTimestamp(toolData.timestamp),
        }

        if (functionName === 'sandbox_switch' && status === 'called' && !restoringRef.current) {
          const args = toolContent.args as Record<string, unknown>
          const target =
            typeof args?.target === 'string' ? args.target.toLowerCase() : ''
          const resultTarget =
            typeof toolContent.content?.result === 'object' && toolContent.content?.result
              ? String((toolContent.content?.result as Record<string, unknown>).provider_type ?? '')
              : ''
          const cliId =
            typeof args?.cli_server_id === 'string' ? args.cli_server_id : ''
          const error = toolContent.content?.error as string | undefined
          const title = error ? 'Runtime switch failed' : 'Runtime switched'
          const targetLabel =
            target === 'cli' || target === 'cli_server' || resultTarget === 'cli' ? 'CLI' : 'Sandbox'
          const description = error
            ? error
            : targetLabel === 'CLI' && cliId
              ? `Now using CLI server ${cliId.slice(0, 6)}`
              : `Now using ${targetLabel}`
          addToast({
            type: error ? 'error' : 'info',
            title,
            description,
            duration: 6000,
          })
        }
        const lastTool = lastToolRef.current

        if (lastTool && lastTool.tool_call_id === toolContent.tool_call_id) {
          Object.assign(lastTool, toolContent)
          updateMessages([...messagesRef.current])
        } else {
          if (!isCopilotSurface && lastStepRef.current && lastStepRef.current.status === 'running') {
            lastStepRef.current.tools.push(toolContent)
            updateMessages([...messagesRef.current])
          } else {
            appendMessage({
              id: toolContent.tool_call_id || createMessageId('tool'),
              type: 'tool',
              content: toolContent,
            })
          }
          lastToolRef.current = toolContent
        }
        if (toolContent.name !== 'message') {
          startDisplayLock(toolContent.tool_call_id, 'tool')
        }

        if (toolContent.name !== 'message') {
          lastNoMessageToolRef.current = toolContent
          if (!restoringRef.current && (realTimeRef.current || toolContent.status === 'calling')) {
            if (canAutoOpenToolPanel(toolContent)) {
              handleToolPanelOpen(toolContent, isLiveTool(toolContent))
            }
          }
        }
        return
      }

      if (event.event === 'step') {
        const stepData = event.data as Partial<StepEventData>
        const status = stepData.status
        if (!status) return
        const description = typeof stepData.description === 'string' ? stepData.description : ''
        const timestamp = coerceTimestamp(stepData.timestamp)
        const stepId = typeof stepData.id === 'string' && stepData.id ? stepData.id : createMessageId('step')
        if (isCopilotSurface) {
          if (status === 'completed') {
            setCopilotStatus(null)
          } else if (status === 'failed') {
            setCopilotStatus('Step failed')
          } else {
            setCopilotStatus(`Step ${status}: ${description}`)
          }
        }
        if (status === 'running') {
          const stepContent: StepContent = {
            ...(stepData as StepEventData),
            id: stepId,
            status,
            description,
            timestamp,
            tools: [],
          }
          appendMessage({
            id: stepId,
            type: 'step',
            content: stepContent,
          })
          lastStepRef.current = stepContent
        } else if (status === 'completed') {
          if (lastStepRef.current) {
            lastStepRef.current.status = status
            updateMessages([...messagesRef.current])
          }
        } else if (status === 'failed') {
          if (isCopilotSurface) {
            setCopilotStatus('Step failed')
          }
        }
        setPlan((current) => {
          const steps = current?.steps ? [...current.steps] : []
          const index = steps.findIndex((step) => step.id === stepId)
          if (index >= 0) {
            steps[index] = {
              ...steps[index],
              ...(stepData as StepEventData),
              id: stepId,
              status,
              description,
              timestamp,
            }
          } else {
            steps.push({
              ...(stepData as StepEventData),
              id: stepId,
              status,
              description,
              timestamp,
            })
          }
          return {
            event_id: current?.event_id || stepData.event_id || createMessageId('plan'),
            timestamp,
            metadata: stepData.metadata,
            steps,
          }
        })
        return
      }

      if (event.event === 'error') {
        const errorData = event.data as Partial<ErrorEventData>
        const errorMessage =
          typeof errorData.error === 'string' && errorData.error ? errorData.error : 'Unexpected error'
        const timestamp = coerceTimestamp(errorData.timestamp)
        appendMessage({
          id: createMessageId('error'),
          type: 'assistant',
          content: {
            content: errorMessage,
            timestamp,
          } as MessageContent,
        })
        setCopilotStatus('Error')
        if (sessionId) {
          upsertSession(sessionId, {
            status: 'failed',
            updated_at: timestamp,
          })
        }
        if (!restoringRef.current) {
          reasoningLocksRef.current.clear()
          if (displayLockRef.current) {
            displayLockRef.current = null
            setDisplayLockState(null)
          }
          if (displayLockTimerRef.current) {
            window.clearTimeout(displayLockTimerRef.current)
            displayLockTimerRef.current = null
          }
          flushBufferedEvents()
        }
        return
      }

      if (event.event === 'title') {
        const titleData = event.data as Partial<TitleEventData>
        const nextTitle = typeof titleData.title === 'string' ? titleData.title : ''
        if (!nextTitle) return
        setTitle(nextTitle)
        if (sessionId) {
          upsertSession(sessionId, { title: nextTitle })
        }
        return
      }

      if (event.event === 'plan') {
        const planData = event.data as Partial<PlanEventData>
        setPlan({
          ...(planData as PlanEventData),
          steps: Array.isArray(planData.steps) ? planData.steps : [],
          timestamp: coerceTimestamp(planData.timestamp),
        })
        return
      }

      if (event.event === 'wait') {
        if (isCopilotSurface) {
          setCopilotStatus('Waiting for your input')
        }
        return
      }

      if (event.event === 'done') {
        if (isCopilotSurface) {
          setCopilotStatus(null)
        }
        if (sessionId) {
          upsertSession(sessionId, {
            status: 'completed',
            updated_at: Math.floor(Date.now() / 1000),
          })
        }
        if (!restoringRef.current && reasoningLocksRef.current.size > 0) {
          reasoningLocksRef.current.clear()
          flushBufferedEvents()
        }
      }
    },
