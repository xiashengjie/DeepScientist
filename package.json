{
  "name": "deepscientist",
  "version": "0.1.0",
  "private": true,
  "description": "DeepScientist Core skeleton",
  "bin": {
    "ds": "bin/ds.js",
    "ds-cli": "bin/ds.js",
    "resear": "bin/ds.js",
    "research": "bin/ds.js"
  },
  "scripts": {
    "ds": "node ./bin/ds.js",
    "start": "node ./bin/ds.js daemon",
    "install:local": "bash ./install.sh",
    "ui:install": "npm --prefix src/ui install",
    "ui:dev": "npm --prefix src/ui run dev",
    "ui:build": "npm --prefix src/ui run build",
    "tui:install": "npm --prefix src/tui install",
    "tui:build": "npm --prefix src/tui run build",
    "postinstall": "npm --prefix src/ui install && npm --prefix src/ui run build && npm --prefix src/tui install && npm --prefix src/tui run build"
  }
}
